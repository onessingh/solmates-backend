# ============================================
# SOLMATES BACKEND — ENVIRONMENT TEMPLATE
# ============================================
# Copy to .env and fill in ALL real values.
# NEVER commit .env to source control.
# This file (.env.example) is safe to commit.
#
# CRITICAL SECURITY: If .env was ever committed or exposed:
# 1. Rotate MongoDB password immediately in Atlas
# 2. Restrict IP access in Atlas Network Access
# 3. Enable TLS (Atlas uses TLS by default)
# ============================================

# Server
NODE_ENV=production
PORT=3000

# MongoDB Atlas Connection
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=solmates

# Admin Credentials
# Generate: node scripts/generate-admin-credentials.js
ADMIN_ID=CHANGE_ME_unique_admin_id
ADMIN_PASSWORD_HASH=CHANGE_ME_bcrypt_hash_from_script

# JWT Secret — MUST be 64+ chars in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_character_hex_string_minimum

# Frontend URL (comma-separated, no trailing slash)
# Local: http://localhost:8000,http://127.0.0.1:8000
# Production: https://teamsolmates.netlify.app
# Netlify preview: add https://*.netlify.app for preview deployments
FRONTEND_URL=https://teamsolmates.netlify.app

# Session IP Binding (default: false)
# false = Admin can login from multiple devices (RECOMMENDED)
# true  = Session locked to login device IP (breaks multi-device/mobile access)
SESSION_IP_BINDING=false

# Session expiry
SESSION_EXPIRY_HOURS=2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Logging (error, warn, info, debug)
LOG_LEVEL=info

# AI Chatbot (DeepSeek) — optional; if not set, chatbot uses keyword fallback
# Get free API key: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-1b878a7886a84071be1224f4995d5f0e
